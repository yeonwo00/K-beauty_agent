    score_components: dict[str, float] = field(
        default_factory=lambda: {
            "ingredient_evidence": 0.0,
            "skin_fit": 0.0,
            "category_match": 0.0,
            "review_confidence": 0.0,
            "personalization": 0.0,
            "penalties": 0.0,
        }
    )
